# Copy to backend.hcl and adjust if you used different bootstrap names.
#
#   cp backend.hcl.example backend.hcl
#
# backend.hcl is gitignored; do not commit account-specific values.

bucket         = "fbp-terraform-state"
key            = "github_actions_mpd_ingest/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
# S3-native locking (Terraform 1.10+). Replaces deprecated dynamodb_table.
use_lockfile   = true
