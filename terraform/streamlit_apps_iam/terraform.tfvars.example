# Copy to terraform.tfvars and adjust as needed.
#
#   cp terraform.tfvars.example terraform.tfvars

aws_region            = "us-east-1"
s3_bucket             = "dn-lakehouse-dev"
athena_results_prefix = "logs/athena-results"

draft_iam_user_name    = "streamlit-draft-tool"
inseason_iam_user_name = "streamlit-inseason-tool"
dynamodb_table_prefix  = "fantasy_baseball_draft"

# Set false after #147 removes runtime CreateTable and tables are pre-created.
allow_dynamodb_create_table = true
